OPENCLAW_IMAGE=openclaw:local

# Each instance gets its own config + workspace directories (relative to this folder)
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace

# Gateway listen port (host)
OPENCLAW_GATEWAY_PORT=18791
OPENCLAW_GATEWAY_BIND=lan

# Gateway auth token (shared with clients you want to connect)
OPENCLAW_GATEWAY_TOKEN=replace-with-random-token

# Model / provider keys for this instance
ANTHROPIC_API_KEY=replace-with-key
OPENAI_API_KEY=replace-with-key

# Telegram Bot API token for this quant instance
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
