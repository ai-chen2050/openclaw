{
    // Quant instance default Telegram group allowlist.
    // Adjust the ID if you change groups; this example allows a single group
    // and keeps mention gating on by default.
    "channels": {
        "telegram": {
            "enabled": true,
            "dmPolicy": "pairing",
            "groups": {
                "-1003897330654": {
                    "requireMention": true
                }
            }
        }
    }
}